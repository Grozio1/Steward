      },
      "edgeToEdgeEnabled": true,
      "package": "com.wortmanip.steward"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c3204937-8a00-48e4-8ffe-24d818951dd4"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
